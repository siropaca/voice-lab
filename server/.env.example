# voice·lab 環境変数テンプレート
# このファイルを server/.env にコピーし、持っているキーだけ記入する。
# 記入したキーに対応するモデルだけが GUI に表示される（未記入のものは非表示）。
#   cp server/.env.example server/.env

# OpenAI — TTS: gpt-4o-mini-tts / STT: gpt-realtime-whisper・gpt-4o-transcribe
# 取得: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ElevenLabs — TTS: Flash v2.5・v3 / STT: Scribe v2 Realtime
# 取得: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Deepgram — STT: Flux Multilingual・Nova-3
# 取得: https://console.deepgram.com/
DEEPGRAM_API_KEY=

# Aivis Cloud — TTS: AivisSpeech
# 取得: https://aivis-project.com/cloud-api/
AIVIS_API_KEY=

# Google Cloud — TTS: Gemini 2.5 Flash TTS・Chirp 3 HD / STT: Chirp 3
# 事前に Text-to-Speech API と Speech-to-Text API を有効化し、サービスアカウントキー(JSON)を発行する。
# GOOGLE_CLOUD_PROJECT           : プロジェクト ID（Google 系モデルの有効判定に使用）
# GOOGLE_APPLICATION_CREDENTIALS : サービスアカウント JSON のパス（ローカル実行では必須）
# GOOGLE_SPEECH_LOCATION         : Google STT のリージョン（既定 us）
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SPEECH_LOCATION=us
