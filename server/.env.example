# voice·lab 環境変数テンプレート
# このファイルを server/.env にコピーし、持っているキーだけ記入する。
# 記入したキーに対応するモデルだけが GUI に表示される（未記入のものは非表示）。
#   cp server/.env.example server/.env

# OpenAI — TTS: gpt-4o-mini-tts / STT: gpt-realtime-whisper・gpt-4o-transcribe
# 取得: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ElevenLabs — TTS: Flash v2.5・v3 / STT: Scribe v2 Realtime
# 取得: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Deepgram — STT: Flux Multilingual・Nova-3
# 取得: https://console.deepgram.com/
DEEPGRAM_API_KEY=

# Aivis Cloud — TTS: AivisSpeech
# 取得: https://aivis-project.com/cloud-api/
AIVIS_API_KEY=

# Google Cloud — TTS: Gemini 2.5 Flash TTS・Chirp 3 HD / STT: Chirp 3
# セットアップ（つまずきポイント）:
#   1) TTS と STT の両方の API を有効化:
#      gcloud services enable texttospeech.googleapis.com speech.googleapis.com
#   2) STT を使うならサービスアカウントに roles/speech.editor を付与（無いと 403）
#   3) Gemini TTS を使うなら追加で roles/aiplatform.user（Chirp 3 HD だけなら不要）
#      ※ Vertex AI は 2026 に「Gemini Enterprise Agent Platform」へ改称。API/ロール名は同じ
#   4) サービスアカウント JSON を発行し、下記に絶対パスで指定（相対パスは server/ 起点で解決される）
# ローカルは JSON の代わりに `gcloud auth application-default login`＋GOOGLE_CLOUD_PROJECT だけでも可。
# GOOGLE_CLOUD_PROJECT           : プロジェクト ID（Google 系モデルの有効判定に使用）
# GOOGLE_APPLICATION_CREDENTIALS : サービスアカウント JSON のパス（ADC ログインなら空でも可）
# GOOGLE_SPEECH_LOCATION         : Google STT のリージョン（us か eu のみ。jp / global は不可）
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SPEECH_LOCATION=us
